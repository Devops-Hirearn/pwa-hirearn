# API URL must end with /api (same as mobile app)
NEXT_PUBLIC_API_URL=https://api-hirearn.onrender.com/api

# Mobile browser on the same Wi‑Fi: run the API on 0.0.0.0 too, set this to your PC LAN IP, e.g.
# NEXT_PUBLIC_API_URL=http://192.168.1.12:5000/api
# Then: npm run dev → open http://192.168.1.12:3000 on the phone (replace with your IP).

# If the dev server warns about blocked /_next/webpack-hmr, add the host it prints (often your LAN IP):
# NEXT_DEV_ALLOWED_ORIGINS=192.168.1.36,http://192.168.1.36:3000
